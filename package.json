{
  "name": "roadstar-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "backend:legacy": "npm --prefix backend/node run start",
    "backend:python": "uvicorn backend.python.app.main:app --reload --host 0.0.0.0 --port 3000",
    "test:python": "python3 -m pytest -q backend/python/tests",
    "smoke": "python3 backend/python/tests/smoke.py"
  }
}
